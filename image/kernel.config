# reference-workload Linux direct-boot config seed.
# Package refwork-d7t.8 turns this seed into the pinned kernel artifact.

CONFIG_64BIT=y
CONFIG_X86_64=y
CONFIG_SMP=n
CONFIG_MODULES=n
CONFIG_BLK_DEV_INITRD=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_TMPFS=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y

CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_MMIO=y

CONFIG_NET=n
CONFIG_WIRELESS=n
CONFIG_SOUND=n
CONFIG_HID=n
CONFIG_USB_SUPPORT=n
CONFIG_MODULE_UNLOAD=n
