#!/usr/bin/env bash
# record-ramdiff — launch the M6 discovery/trajectory hand-play session.
# Usage: record-ramdiff [session-name] [--resume]
#   Default: start FRESH — an existing non-empty session dir is rotated
#   aside to <name>.bak-N (never deleted).
#   --resume: replay interactive.padlog to restore state, then append.
set -euo pipefail

SESSION_NAME="discovery-01"
SESSION_NAME_SET=0
RESUME=0
for arg in "$@"; do
  case "$arg" in
    --resume) RESUME=1 ;;
    -h|--help)
      sed -n "2,6p" "$0" | sed "s/^# \{0,1\}//"; exit 0 ;;
    -*) echo "error: unknown flag $arg" >&2; exit 1 ;;
    *)
      if [ "$SESSION_NAME_SET" -eq 1 ]; then
        echo "error: more than one session name given ($SESSION_NAME, $arg)" >&2
        exit 1
      fi
      SESSION_NAME="$arg"; SESSION_NAME_SET=1 ;;
  esac
done
if ! [[ "$SESSION_NAME" =~ ^[A-Za-z0-9_-]+$ ]]; then
  echo "error: session name must match [A-Za-z0-9_-]+ (got: $SESSION_NAME)" >&2
  exit 1
fi

# Resolve the repo root from this script's real location (the installed copy
# in ~/.local/bin is a symlink into the repo), so any clone location works.
SRC="$0"
while [ -L "$SRC" ]; do
  DIR="$(cd "$(dirname "$SRC")" && pwd)"
  SRC="$(readlink "$SRC")"
  if [[ "$SRC" != /* ]]; then SRC="$DIR/$SRC"; fi
done
REPO_ROOT="$(cd "$(dirname "$SRC")/.." && pwd)"
RAMDIFF="$REPO_ROOT/target/release/ramdiff"

# The private root (ROMs + sessions) is resolved from a pointer file outside
# every checkout; its location never appears in this repo (GATE-RECORD-ASK1).
POINTER="$HOME/.agents/projects/reference-workload/private-root.path"
if [ ! -s "$POINTER" ]; then
  echo "error: private-root pointer file missing: $POINTER" >&2
  echo "       write the operator-approved private root into it (one absolute" >&2
  echo "       path, no trailing slash) before running this tool." >&2
  exit 1
fi
PRIVATE_ROOT="$(head -n1 "$POINTER")"
ROM_DIR="$PRIVATE_ROOT/ROMs/SNES"
SESSION_DIR="$PRIVATE_ROOT/ramdiff/$SESSION_NAME"

[ -x "$RAMDIFF" ] || { echo "error: $RAMDIFF not built" >&2; exit 1; }

# Single-ROM guard: exactly one regular file must be present.
shopt -s nullglob
roms=("$ROM_DIR"/*)
shopt -u nullglob
if [ "${#roms[@]}" -ne 1 ]; then
  echo "error: expected exactly 1 entry in $ROM_DIR, found ${#roms[@]}" >&2
  exit 1
fi
if [ ! -f "${roms[0]}" ]; then
  echo "error: the single entry in $ROM_DIR is not a regular file" >&2
  exit 1
fi

# Fresh by default: rotate an existing non-empty session aside (keep data).
if [ "$RESUME" -eq 0 ] && [ -d "$SESSION_DIR" ] && [ -n "$(ls -A "$SESSION_DIR" 2>/dev/null)" ]; then
  n=1
  while [ -e "$SESSION_DIR.bak-$n" ]; do n=$((n+1)); done
  mv "$SESSION_DIR" "$SESSION_DIR.bak-$n"
  echo "note: previous session moved to ${SESSION_DIR##*/}.bak-$n (use --resume to append instead)" >&2
fi
if [ "$RESUME" -eq 1 ] && [ ! -f "$SESSION_DIR/interactive.padlog" ]; then
  echo "note: --resume given but no prior session found; starting fresh." >&2
fi

# Gamepad preflight. Either way the F310 back switch must be on D
# (DirectInput): neither host has an XInput driver for it.
case "$(uname -s)" in
  Linux)
    # No xpad driver on the lab kernel, so XInput mode binds NOTHING. On
    # replug, logind auto-grants a seat ACL to joystick devices
    # (70-uaccess.rules).
    echo "gamepad: F310 back switch on D; if undetected, unplug/replug it once." >&2
    # Command substitution instead of `| grep -q`: under pipefail, grep -q
    # exiting early can SIGPIPE find and make the check misfire.
    if [ -z "$(find /dev/input -maxdepth 1 -name "event*" -readable 2>/dev/null)" ]; then
      echo "note: no readable /dev/input/event* yet — a D-mode replug should fix it;" >&2
      echo "      fallback: sudo usermod -aG input ${USER:-$(id -un)} (then log out/in)." >&2
    fi
    ;;
  Darwin)
    # ramdiff auto-detects HID gamepads via gilrs/IOKit; plug in before
    # launch (pads connected mid-session are not picked up).
    echo "gamepad: F310 back switch on D; plug in before launching." >&2
    # If L/R (or any button) land wrong: run ramdiff with --pad-debug to see
    # the pad's UUID and mapping source, then export an exact-UUID SDL
    # mapping line via SDL_GAMECONTROLLERCONFIG before launching this
    # wrapper — the env var passes through exec below and gilrs honors it.
    ;;
esac

# In-window controls: F5 = WRAM dump, M = mute/unmute audio, Esc = quit.

mkdir -p "$SESSION_DIR"
resume_args=()
if [ "$RESUME" -eq 1 ]; then resume_args+=(--resume); fi
# ${arr[@]+...} guard: expanding an empty array under `set -u` is fatal on
# bash < 4.4 (macOS ships 3.2 as /bin/bash).
exec "$RAMDIFF" record --interactive ${resume_args[@]+"${resume_args[@]}"} \
  --rom "${roms[0]}" \
  --session "$SESSION_DIR"
